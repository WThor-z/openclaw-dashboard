{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true
  },
  "include": [
    "infra/**/*.mjs",
    "apps/**/*",
    "packages/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
